# ── Alpha-Harvest Wheel Bot — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────
# Discord webhook URL (Server Settings → Integrations → Webhooks → Copy URL)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── Optional: Enhanced Data Feeds ─────────────────────────────────────────────

# Unusual Whales API key — for real dark pool prints
# Sign up: https://unusualwhales.com/
UNUSUAL_WHALES_API_KEY=

# Quiver Quant API key — for WallStreetBets social sentiment
# Sign up: https://www.quiverquant.com/
SENTIMENT_API_KEY=
